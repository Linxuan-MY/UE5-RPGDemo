root = true

[*]
charset = utf-8
insert_final_newline = true
trim_trailing_whitespace = true

[*.{c,cc,cpp,cxx,h,hh,hpp,inl,cs}]
indent_style = tab
indent_size = 4
tab_width = 4

[*.{ini,json,uproject,uplugin}]
indent_style = tab
indent_size = 4
tab_width = 4

[*.{bat,cmd,ps1}]
end_of_line = crlf

[*.sh]
end_of_line = lf

[*.md]
trim_trailing_whitespace = false
